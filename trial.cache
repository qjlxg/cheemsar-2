iv class="btn_box">\n\t\t\t<a id="more_picsee"\n\t\t\thref="https://picsee.soci.vip/" \n\t\t\tclass="btn btn-success btn-lg"\n\t\t\ttarget="_blank">\n\t\t\tMore\t\t\t</a>\n\t\t</div>\n\t\t<hr />\n\t\t<p>PicSee optimize your share link on social media</p>\n\t</div>\n</div>\n\n<!-- ad -->\n<div id="ad_bar">\n\t<ins class="rmax" data-rmax-space-id="0cf0b05622074fba" data-rmax-space-type="BANNER" data-rmax-space-width="320px" data-rmax-space-height="50px"></ins>\n\t<script async="async" src="//tenmax-static.cacafly.net/ssp/adsbytenmax.js"></script>\n\n<script type="text/javascript">\n\n// 定義 trip.com 分潤連結\nconst tripAffiliateUrl = \'https://trip.com/?Allianceid=5129454&SID=102320177&trip_sub1=redirect-not-found\';\n\n// 離開頁面時跳轉到 trip.com\nconst handleVisibility = function() {\n if (document.visibilityState === \'hidden\') {\n window.location.replace(tripAffiliateUrl);\n }\n};\ndocument.addEventListener(\'visibilitychange\', handleVisibility);\n\nconst ua = navigator.userAgent;\nif((/iPhone|iPad/i.test(ua) || /Android/i.test(ua))) {\n let morePicSeeBtn = document.getElementById(\'more_picsee\');\n morePicSeeBtn.href = "#";\n morePicSeeBtn.removeAttribute("target");\n \n // 統一使用一個函數處理重導向\n const redirectToTrip = () => {\n sessionStorage.removeItem(\'shouldRedirect\');\n window.location.replace(tripAffiliateUrl);\n };\n\n morePicSeeBtn.onclick = () => {\n document.removeEventListener(\'visibilitychange\', handleVisibility);\n sessionStorage.setItem(\'shouldRedirect\', \'true\');\n window.open(\'https://picsee.soci.vip/\');\n window.location.href = tripAffiliateUrl;\n };\n\n // 檢查 sessionStorage\n if (sessionStorage.getItem(\'shouldRedirect\')) {\n redirectToTrip();\n }\n\n // 返回事件的額外保險\n window.addEventListener(\'pageshow\', function(event) {\n if (event.persisted || sessionStorage.getItem(\'shouldRedirect\')) {\n redirectToTrip();\n }\n });\n}\n\nfunction showHideHTML(id){\n\tif($(id).is(\':visible\')) $(id).hide(200);\n\telse $(id).show(200);\n}\n\n(function(d, s, id) {\n var js, fjs = d.getElementsByTagName(s)[0];\n if (d.getElementById(id)) return;\n js = d.createElement(s); js.id = id;\n js.src = "//connect.facebook.net/zh_TW/sdk.js#xfbml=1&version=v2.6&appId=150378901782986";\n fjs.parentNode.insertBefore(js, fjs);\n}(document, \'script\', \'facebook-jssdk\'));\n\n</script>\n<!--div class="fb-ad" data-placementid="750551648307236_1273338962695166" data-format="320x50" data-testmode="false"></div-->\n</div>\n\n<div id="help_icon" onmouseenter="showHideHTML(\'#help_box\');">Help</div>\n<div id="help_box" onmouseleave="showHideHTML(\'#help_box\');">\n\t<div id="fb-root"></div>\n\t<div class="fb-page" data-href="https://www.facebook.com/picsee.co" data-tabs="messages" data-height="300" data-small-header="true" data-adapt-container-width="true" data-hide-cover="true" data-show-facepile="false"><blockquote cite="https://www.facebook.com/picsee.co" class="fb-xfbml-parse-ignore"><a href="https://www.facebook.com/picsee.co">PicSee 皮克看見</a></blockquote></div>\n</div>\n\n</body>\n</html>')
